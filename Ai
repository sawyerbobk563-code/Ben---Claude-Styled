// ── FILE UPLOAD ───────────────────────────────────────────────
let currentUploadTarget = 1;
function triggerUpload(t) { currentUploadTarget=t; document.getElementById('fileInput').click(); }

async function handleFile(e) {
  const file = e.target.files[0]; if (!file) return; e.target.value='';
  let txt = '';
  pendingFileName = file.name;
  try {
    if (file.type.startsWith('image/')) {
      showFilePill(currentUploadTarget, 'ocr-loading');
      txt = await extractTextFromImage(file);
      showFilePill(currentUploadTarget, 'ocr-done');
    } else {
      const raw = await readAsText(file);
      txt = `[Attached file: ${file.name}]

${raw}`;
    }
  } catch(err) {
    txt = `[File: ${file.name}] — could not read: ${err.message}`;
    showFilePill(currentUploadTarget, 'ocr-error');
  }
  pendingFileText = txt;
  document.getElementById('sendBtn').classList.add('ready');
  document.getElementById('sendBtn2').classList.add('ready');
  document.getElementById('addBtn').classList.add('has-file');
  document.getElementById('addBtn2').classList.add('has-file');
}

async function extractTextFromImage(file) {
  return new Promise((resolve) => {
    const reader = new FileReader();
    reader.onload = (ev) => {
      const img = new Image();
      img.onload = () => {
        const canvas = document.createElement('canvas');
        const MAX = 1600;
        let w = img.width, h = img.height;
        if (w > MAX || h > MAX) { const s = MAX/Math.max(w,h); w=Math.round(w*s); h=Math.round(h*s); }
        canvas.width = w; canvas.height = h;
        canvas.getContext('2d').drawImage(img, 0, 0, w, h);

        function doOCR() {
          window.Tesseract.recognize(canvas, 'eng', { logger: ()=>{} })
            .then(({ data: { text } }) => {
              const clean = text.trim();
              if (clean.length > 8) {
                showToast('📷 Text extracted from image ✓');
                resolve(`[Image OCR: ${file.name}]

Extracted text:
${clean}

(Note: Only the extracted text was sent, not the image itself.)`);
              } else {
                showToast('📷 No text found in image', 'warn');
                resolve(`[Image: ${file.name}] — No readable text detected. Size: ${(file.size/1024).toFixed(1)} KB.`);
              }
            }).catch(() => {
              resolve(`[Image: ${file.name}] — OCR failed. Size: ${(file.size/1024).toFixed(1)} KB.`);
            });
        }

        if (window.Tesseract) {
          doOCR();
        } else {
          const s = document.createElement('script');
          s.src = 'https://cdnjs.cloudflare.com/ajax/libs/tesseract.js/5.1.0/tesseract.min.js';
          s.onload = doOCR;
          s.onerror = () => resolve(`[Image: ${file.name}] — OCR library unavailable. Size: ${(file.size/1024).toFixed(1)} KB.`);
          document.head.appendChild(s);
        }
      };
      img.onerror = () => resolve(`[Image: ${file.name}] — could not load image`);
      img.src = ev.target.result;
    };
    reader.readAsDataURL(file);
  });
}


function readAsText(f){return new Promise((r,j)=>{const fr=new FileReader();fr.onload=()=>r(fr.result);fr.onerror=()=>j(new Error('Read failed'));fr.readAsText(f);});}
function readAsBase64(f){return new Promise((r,j)=>{const fr=new FileReader();fr.onload=()=>r(fr.result.split(',')[1]);fr.onerror=()=>j(new Error('Read failed'));fr.readAsDataURL(f);});}
function showFilePill(t, status) {
  const barId = t===2 ? 'filePreviewBar2' : 'filePreviewBar';
  const bar = document.getElementById(barId); bar.style.display='block';
