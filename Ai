// Allow AI to push content into canvas with user permission
let pendingCanvasContent = null;
let pendingCanvasTitle = null;

function setCanvasContent(newContent, title) {
  const editor = document.getElementById('canvasEditor');
  const existingContent = editor.value.trim();

  if (existingContent && existingContent.length > 20) {
    // Canvas has content — ask permission to overwrite
    pendingCanvasContent = newContent;
    pendingCanvasTitle = title;
    showCanvasPermissionBanner(title);
  } else {
    // Canvas is empty — write directly
    applyCanvasContent(newContent, title);
  }
}

function showCanvasPermissionBanner(title) {
  // Remove existing banner
  const existing = document.getElementById('canvasAiBanner');
  if (existing) existing.remove();

  const banner = document.createElement('div');
  banner.id = 'canvasAiBanner';
  banner.className = 'canvas-ai-banner';
  banner.innerHTML = `
