function generateChatId() { return 'chat_' + Date.now() + '_' + Math.random().toString(36).slice(2,7); }

async function autoChatName(firstMsg) {
  try {
    const resp = await fetch(API_URL, {
      method: 'POST',
      headers: {'Content-Type':'application/json','Authorization':'Bearer '+API_KEY},
      body: JSON.stringify({
        model: 'llama-3.1-8b-instant',
        max_completion_tokens: 12,
        temperature: 0.3,
        messages: [
          {role:'system', content:'Reply with ONLY a short title (3-6 words, no quotes, no punctuation at end) that captures what this conversation is about.'},
          {role:'user', content: firstMsg.slice(0, 200)}
        ]
      })
    });
    const data = await resp.json();
    const name = data?.choices?.[0]?.message?.content?.trim();
    return name && name.length < 60 ? name : firstMsg.slice(0,40);
  } catch { return firstMsg.slice(0,40); }
}

function renderChatHistory() {
  const list = document.getElementById('historyList');
  list.innerHTML = '';
  const chats = loadChatHistory().reverse();
  chats.forEach(chat => {
    const item = document.createElement('div');
    item.className = 'chat-history-item';
    const dateStr = new Date(chat.timestamp).toLocaleDateString('en-US',{month:'short',day:'numeric'});
    item.innerHTML = `
      <svg class="chi-icon" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
      <span class="chi-name" title="${chat.name}">${chat.name}</span>
      <span class="chi-date">${dateStr}</span>
      <button class="chi-del" onclick="deleteSavedChat('${chat.id}',event)" title="Delete">×</button>
    `;
    item.onclick = (e) => { if(e.target.classList.contains('chi-del')) return; loadSavedChat(chat.id); };
    list.appendChild(item);
  });
}

function loadSavedChat(id) {
  const chats = loadChatHistory();
  const chat = chats.find(c => c.id === id);
  if (!chat) return;
  history = [...chat.messages];
  currentChatId = id;
  document.getElementById('welcomeView').style.display = 'none';
  document.getElementById('chatView').style.display = 'flex';
  activeInputId = 1;
  const msgsEl = document.getElementById('messages');
  msgsEl.innerHTML = '';
  chat.messages.forEach(msg => {
    if (msg.role === 'system') return;
    const wrap = document.createElement('div');
    wrap.className = 'msg ' + msg.role;
    if (msg.role === 'assistant') {
      const av = document.createElement('div'); av.className = 'avatar';
      av.innerHTML = '<img src="data:image/png;base64," style="width:100%;height:100%;object-fit:cover;border-radius:9px;" alt="Ben">';
      wrap.appendChild(av);
    }
    const bw = document.createElement('div'); bw.className = 'bubble-wrap';
    const bubble = document.createElement('div'); bubble.className = 'bubble';
    if (msg.role === 'assistant') {
      bubble.innerHTML = renderMarkdown(msg.content);
    } else {
      bubble.textContent = msg.content;
    }
    bw.appendChild(bubble);
    if (msg.role === 'assistant') addCopyBtn(bw, msg.content);
    wrap.appendChild(bw);
    msgsEl.appendChild(wrap);
  });
  msgsEl.scrollTop = msgsEl.scrollHeight;
  closeHistory();
  setNavActive('home');
}

function deleteSavedChat(id, e) {
  e.stopPropagation();
  let chats = loadChatHistory();
  chats = chats.filter(c => c.id !== id);
  saveChatHistory(chats);
  renderChatHistory();
}

async function saveCurrentChat(firstUserMsg) {
  if (!currentChatId) currentChatId = generateChatId();
  let chats = loadChatHistory();
  const existing = chats.find(c => c.id === currentChatId);
  let name = existing?.name;
  if (!name) name = await autoChatName(firstUserMsg);
  const chatObj = {
    id: currentChatId,
    name: name,
    timestamp: existing?.timestamp || Date.now(),
    messages: history.filter(m => m.role !== 'system')
  };
  if (existing) { const idx = chats.findIndex(c => c.id === currentChatId); chats[idx] = chatObj; }
  else chats.push(chatObj);
  saveChatHistory(chats);
}

