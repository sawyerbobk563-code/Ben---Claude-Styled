function tryAutoSwitch(reason) {
  for (let i=currentModelIdx+1; i<MODEL_POOL.length; i++) {
    const st=rlState[MODEL_POOL[i].id];
    if(st.remainingRPD>0 && st.remainingTPM>100) {
      const prev=currentModel().label; currentModelIdx=i; syncModelUI();
      showToast(`Auto-switched: ${prev} → ${MODEL_POOL[i].label} (${reason})`,'warn');
      return true;
    }
  }
  showToast('All models at rate limit — please wait.','warn'); return false;
}
function checkLimitsBeforeSend() {
  const st=currentModelState();
  if(st.remainingRPD/st.totalRPD<0.1||st.remainingRPD<=0) return tryAutoSwitch('daily request limit');
  if(st.remainingTPM/st.totalTPM<0.1||st.remainingTPM<=0) return tryAutoSwitch('token limit');
  return true;
}
function decrementLocal(est) {
  const st=currentModelState();
  st.remainingRPD=Math.max(0,st.remainingRPD-1);
  st.remainingTPM=Math.max(0,st.remainingTPM-est);
  recordRequest(currentModel().id, est);
}

