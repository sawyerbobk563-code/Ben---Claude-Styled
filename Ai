  row.style.cssText = 'display:flex;gap:4px;align-items:center';

  const ci='<svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>';
  const ck='<svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="20 6 9 17 4 12"/></svg>';
  const ri='<svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 .49-3.85"/></svg>';

  const copyBtn = document.createElement('button'); copyBtn.className='copy-btn';
  copyBtn.innerHTML=ci+' Copy';
  copyBtn.onclick=()=>{navigator.clipboard.writeText(text);copyBtn.innerHTML=ck+' Copied';copyBtn.classList.add('copied');setTimeout(()=>{copyBtn.innerHTML=ci+' Copy';copyBtn.classList.remove('copied');},1800);};

  row.appendChild(copyBtn);

  // Regenerate button — only on last assistant message
  if (isLast !== false) {
    const regenBtn = document.createElement('button'); regenBtn.className='regen-btn';
    regenBtn.dataset.regen = '1';
    regenBtn.innerHTML = ri + ' Retry';
    regenBtn.onclick = () => regenerateLastResponse();
    row.appendChild(regenBtn);
  }

  bw.appendChild(row);
}

function scrollBottom() {
  requestAnimationFrame(() => {
    msgsEl.scrollTop = msgsEl.scrollHeight;
    updateScrollArrow();
  });
}

// ── SEND MESSAGE ──────────────────────────────────────────────
let isSending = false; // extra guard against double-click

function setSendDisabled(disabled) {
  ['sendBtn','sendBtn2'].forEach(id => {
    const btn = document.getElementById(id);
    if (btn) btn.disabled = disabled;
  });
}

async function sendMessage() {
  if (isSending || isLoading) return; // prevent double-submit
  const inputEl = getInput();
  let text = inputEl.value.trim();
  let fullContent = text;
  if (pendingFileText) fullContent = pendingFileText + (text ? '\n\nUser message: ' + text : '');
  if (!fullContent) return;
  if (!checkLimitsBeforeSend()) return;

  // Immediately lock
  isSending = true;
  setSendDisabled(true);

  if (document.getElementById('welcomeView').style.display !== 'none') showChatView();

  const {bubble:ub} = createMsgEl('user');
  if (pendingFileName && !text) ub.innerHTML=`<span style="opacity:.6;font-size:12px;font-family:var(--mono)"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" style="vertical-align:middle"><path d="M13 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V9z"/><polyline points="13 2 13 9 20 9"/></svg> ${pendingFileName}</span>`;
  else if (pendingFileName) ub.innerHTML=`<span style="opacity:.6;font-size:12px;display:block;margin-bottom:4px;font-family:var(--mono)"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" style="vertical-align:middle"><path d="M13 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V9z"/><polyline points="13 2 13 9 20 9"/></svg> ${pendingFileName}</span>${text}`;
  else ub.textContent = text;

  inputEl.value = ''; inputEl.style.height = 'auto';
  document.getElementById('sendBtn').classList.remove('ready');
  document.getElementById('sendBtn2').classList.remove('ready');
  clearFile();
  history.push({role:'user', content:fullContent});

  isLoading = true;
  decrementLocal(Math.ceil(fullContent.length/4)+200);

  // Show typing indicator
  showTypingIndicator();
  scrollBottom();

  await runAssistant(text);
}

async function regenerateLastResponse() {
  if (isSending || isLoading) return;
  // Remove last assistant turn from history and DOM
  if (history.length > 0 && history[history.length-1].role === 'assistant') {
    history.pop();
  }
  // Remove last assistant message from DOM
  const msgs = msgsEl.querySelectorAll('.msg.assistant');
  if (msgs.length > 0) msgs[msgs.length-1].remove();

  isSending = true;
  setSendDisabled(true);
  isLoading = true;

  const lastUserMsg = history.length > 0 ? history[history.length-1].content : '';
  showTypingIndicator();
  scrollBottom();

  await runAssistant(lastUserMsg.slice(0, 100));
}

async function runAssistant(textForSave) {
  let fullText = '', retried = false;

  async function attempt() {
    const sysPrompt = document.getElementById('systemPrompt').value.trim() || BEN_DEFAULT_PROMPT;
    const temp = parseFloat(document.getElementById('tempSlider').value);
    const maxTok = parseInt(document.getElementById('tokensSlider').value);
    const supportsTools = modelSupportsTools();
    const tools = [];
    if (supportsTools && featState.web)  tools.push({type:'browser_search'});
    if (supportsTools && featState.code) tools.push({type:'code_interpreter'});
    if (!supportsTools && (featState.web || featState.code)) {
      showToast(`Search/Code tools require GPT-OSS models — running ${currentModel().label} without tools.`,'warn');
    }
    const messages = [{role:'system', content:sysPrompt}, ...history];
    const payload = {model:currentModel().id, messages, temperature:temp, max_completion_tokens:maxTok, top_p:1, stream:true, stop:null};
    if (featState.think) payload.reasoning_effort = 'default';
    if (tools.length) payload.tools = tools;

    const resp = await fetch(API_URL, {
      method: 'POST',
      headers: {'Content-Type':'application/json','Authorization':'Bearer '+API_KEY},
      body: JSON.stringify(payload)
    });

    updateRLFromHeaders(resp.headers, currentModel().id);

    if (resp.status === 429 && !retried) {
      retried = true;
      if (tryAutoSwitch('429 rate limit')) { await new Promise(r=>setTimeout(r,600)); return await attempt(); }
      throw new Error('Rate limit reached on all models.');
    }
    if (!resp.ok) {
      const err = await resp.json().catch(()=>({}));
      throw new Error('HTTP '+resp.status+': '+(err?.error?.message||'Unknown error'));
    }

    // Remove typing indicator and create real bubble
    removeTypingIndicator();
    const {bubble:ab, bw} = createMsgEl('assistant');
    let toolShown = false;

    const reader = resp.body.getReader(), decoder = new TextDecoder('utf-8');
    let buffer = '';
    while (true) {
      const {value, done} = await reader.read();
      if (done) break;
      buffer += decoder.decode(value, {stream:true});
      const lines = buffer.split('\n');
      buffer = lines.pop();
      for (const line of lines) {
        const trimmed = line.trim();
        if (!trimmed || !trimmed.startsWith('data:')) continue;
        const data = trimmed.slice(5).trim();
        if (data === '[DONE]') return {ab, bw};
        try {
          const parsed = JSON.parse(data);
          const delta = parsed?.choices?.[0]?.delta;
          const chunk = delta?.content;
          if (chunk) {
            fullText += chunk;
            ab.textContent = fullText;
            scrollBottom();
          }
          if (delta?.tool_calls && !toolShown) {
            toolShown = true;
            const tcName = delta.tool_calls[0]?.function?.name || delta.tool_calls[0]?.type || 'tool';
            ab.innerHTML = `<span style="opacity:.5;font-size:12px;font-family:var(--mono)">${tcName==='browser_search'?'🔍 Searching the web…':'⚙ Running code…'}</span>`;
          }
        } catch {}
      }
    }
    if (buffer.trim().startsWith('data:')) {
      const data = buffer.trim().slice(5).trim();
      if (data && data !== '[DONE]') { try { const c=JSON.parse(data)?.choices?.[0]?.delta?.content; if(c) fullText+=c; } catch {} }
    }
    return {ab, bw};
  }

  let ab, bw;
  try {
    const result = await attempt();
    ab = result?.ab; bw = result?.bw;

    // ── CANVAS DETECTION ──────────────────────────────────────
    const canvasMatch = fullText.match(/```canvas\n([\s\S]*?)```/);
    let displayText = fullText;

    if (canvasMatch) {
      // Explicit canvas block in response
      const canvasRaw = canvasMatch[1];
      const titleMatch = canvasRaw.match(/^TITLE:\s*(.+)/m);
      const canvasTitle = titleMatch ? titleMatch[1].trim() : 'Canvas';
      const canvasContent = canvasRaw.replace(/^TITLE:\s*.+\n---\n?/m, '').trim();
      setCanvasContent(canvasContent, canvasTitle);
      displayText = fullText.replace(/```canvas\n[\s\S]*?```/, `\n\n📋 **Sent to Canvas: "${canvasTitle}"** — see the panel on the right.`);
      showToast(`Canvas updated: "${canvasTitle}" ✓`);
    } else if (canvasOpen && fullText.trim().length > 0) {
      // Canvas is open — route AI output directly into canvas
      const autoTitle = document.getElementById('canvasTitleInput').value || 'Canvas';
      setCanvasContent(fullText.trim(), autoTitle);
      displayText = `📋 *Response sent to canvas.*`;
      showToast('Canvas updated ✓');
    }

    // Route to canvas if canvas panel is open
    const panelOpen = document.getElementById('canvasPanel') && document.getElementById('canvasPanel').classList.contains('open');
    if (panelOpen && !fullText.match(/```canvas[\s\S]*?```/)) {
      setCanvasContent(fullText, 'AI Response');
      displayText = '\u{1F4CB} Sent to canvas.';
    }
    if (ab) {
      ab.innerHTML = renderMarkdown(displayText || '(no response)');
    }
    history.push({role:'assistant', content:fullText});
    // Remove old regen buttons before adding new ones
    msgsEl.querySelectorAll('.regen-btn').forEach(b => b.closest('div[style]')?.remove() || b.remove());
    if (bw) addCopyBtn(bw, fullText, true);
    try { saveCurrentChat(textForSave || ''); } catch(e) {}
  } catch(err) {
    removeTypingIndicator();
    if (!ab) {
      const res = createMsgEl('assistant');
      ab = res.bubble; bw = res.bw;
    }
    ab.textContent = 'Error: ' + err.message; ab.style.color = 'var(--red)';
    if (err.message.includes('429') || err.message.includes('rate')) tryAutoSwitch('error response');
  }

  isLoading = false;
  isSending = false;
  setSendDisabled(false);
  scrollBottom();
}

// ── CLEAR ──────────────────────────────────────────────────────
function clearChat(silent=false) {
  if(!silent && history.length>0 && !confirm('Clear all messages?')) return;
  history=[]; if(msgsEl) msgsEl.innerHTML=''; clearFile();
  currentChatId = null;
  document.getElementById('chatView').style.display='none';
  document.getElementById('welcomeView').style.display='';
  activeInputId=2; setGreeting();
}

// ── INIT ───────────────────────────────────────────────────────
syncModelUI();
loadSavedSystemPrompt();
document.getElementById('userInput2').focus();
renderChatHistory();
</script>
