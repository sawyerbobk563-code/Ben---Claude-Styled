    <button class="banner-deny" onclick="denyCanvasWrite()">Keep</button>
    <button class="banner-allow" onclick="allowCanvasWrite()">Replace</button>
  `;
  const canvasPanel = document.getElementById('canvasPanel');
  canvasPanel.style.position = 'relative';
  canvasPanel.appendChild(banner);
  if (!canvasOpen) openCanvas();
}

function allowCanvasWrite() {
  if (pendingCanvasContent !== null) {
    applyCanvasContent(pendingCanvasContent, pendingCanvasTitle);
    pendingCanvasContent = null; pendingCanvasTitle = null;
  }
  const b = document.getElementById('canvasAiBanner'); if (b) b.remove();
}

function denyCanvasWrite() {
  // Append instead of replace
  if (pendingCanvasContent !== null) {
    const editor = document.getElementById('canvasEditor');
    editor.value += '\n\n---\n\n' + pendingCanvasContent;
    if (pendingCanvasTitle) document.getElementById('canvasTitleInput').value = pendingCanvasTitle;
    updateCanvasWordCount();
    pendingCanvasContent = null; pendingCanvasTitle = null;
  }
  const b = document.getElementById('canvasAiBanner'); if (b) b.remove();
}

function applyCanvasContent(newContent, title) {
  if (!canvasOpen) openCanvas();
  document.getElementById('canvasEditor').value = newContent;
  if (title) document.getElementById('canvasTitleInput').value = title;
  updateCanvasWordCount();
