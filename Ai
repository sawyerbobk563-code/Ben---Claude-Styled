// ── VOICE / MIC ───────────────────────────────────────────────
let recognition=null, isListening=false, listenTarget=0;
function toggleVoice(target) {
  const SR = window.SpeechRecognition || window.webkitSpeechRecognition;
  if (!SR) { alert('Voice input is not supported in this browser.'); return; }
  if (isListening) { recognition.stop(); return; }
  listenTarget = target;
  navigator.mediaDevices.getUserMedia({ audio: true })
    .then(() => startRecognition(SR, target))
    .catch(err => {
      if (err.name === 'NotAllowedError' || err.name === 'PermissionDeniedError') {
        alert('Microphone access was denied.');
      } else alert('Could not access microphone: ' + err.message);
    });
}
function startRecognition(SR, target) {
  recognition = new SR();
  recognition.continuous = true; recognition.interimResults = true; recognition.lang = 'en-US';
  const inputEl  = document.getElementById(target===2 ? 'userInput2' : 'userInput');
  const sendEl   = document.getElementById(target===2 ? 'sendBtn2'   : 'sendBtn');
  let finalText  = inputEl.value;
  recognition.onstart = () => { isListening = true; [document.getElementById('micBtn'), document.getElementById('micBtn2')].forEach(b => b && b.classList.add('mic-active')); };
  recognition.onend = () => { isListening = false; [document.getElementById('micBtn'), document.getElementById('micBtn2')].forEach(b => b && b.classList.remove('mic-active')); };
  recognition.onerror = ev => { isListening = false; [document.getElementById('micBtn'), document.getElementById('micBtn2')].forEach(b => b && b.classList.remove('mic-active')); };
  recognition.onresult = ev => {
    let interim = '';
    for (let i=ev.resultIndex; i<ev.results.length; i++) {
      const t = ev.results[i][0].transcript;
      if (ev.results[i].isFinal) finalText += (finalText ? ' ' : '') + t.trim();
      else interim = t;
    }
    inputEl.value = finalText + (interim ? ' ' + interim : '');
    inputEl.style.height = 'auto';
    inputEl.style.height = Math.min(inputEl.scrollHeight, 130) + 'px';
    sendEl.classList.toggle('ready', inputEl.value.trim().length > 0 || pendingFileText.length > 0);
  };
  recognition.start();
}

// ── MODEL / RATE LIMIT ────────────────────────────────────────
// Sliding window rate limiter
const rlWindow = {};
MODEL_POOL.forEach(m => { rlWindow[m.id] = { minuteReqs:[], dayReqs:[], minuteTokens:[] }; });

function pruneWindows(modelId) {
  const now = Date.now(); const w = rlWindow[modelId];
  w.minuteReqs = w.minuteReqs.filter(r => now - r.ts < 60000);
  w.dayReqs = w.dayReqs.filter(r => now - r.ts < 86400000);
  w.minuteTokens = w.minuteTokens.filter(r => now - r.ts < 60000);
}

function recordRequest(modelId, tokens) {
  const now = Date.now(); const w = rlWindow[modelId];
  w.minuteReqs.push({ts:now}); w.dayReqs.push({ts:now}); w.minuteTokens.push({ts:now, tokens});
  pruneWindows(modelId); updateRLMeter();
}

function getUsageRatios(modelId) {
  pruneWindows(modelId);
  const m = MODEL_POOL.find(x => x.id === modelId); const w = rlWindow[modelId]; const st = rlState[modelId];
  const rpdRatio = (m.rpd - st.remainingRPD) / m.rpd;
  const tpmUsed = w.minuteTokens.reduce((a,b) => a+b.tokens, 0);
  return { rpdRatio: Math.min(rpdRatio,1), tpmRatio: Math.min(tpmUsed/m.tpm,1), rpdLeft:st.remainingRPD, tpmLeft:Math.max(0,m.tpm-tpmUsed) };
}

function updateRLMeter() {
  let meter = document.getElementById('rlMeter');
  if (!meter) {
    meter = document.createElement('div'); meter.id='rlMeter'; meter.className='rl-meter';
    meter.innerHTML = '<div class="rl-meter-row"><span class="rl-meter-label">Req/day</span><div class="rl-meter-bar"><div class="rl-meter-fill good" id="rlFillRPD" style="width:0%"></div></div><span id="rlTextRPD" style="font-size:9px;color:var(--muted2)"></span></div><div class="rl-meter-row"><span class="rl-meter-label">Tok/min</span><div class="rl-meter-bar"><div class="rl-meter-fill good" id="rlFillTPM" style="width:0%"></div></div><span id="rlTextTPM" style="font-size:9px;color:var(--muted2)"></span></div><div style="margin-top:3px;font-size:9px;color:var(--muted2);text-align:center" id="rlModelName"></div>';
    document.body.appendChild(meter);
  }
  const r = getUsageRatios(currentModel().id);
  const rpdPct=Math.round(r.rpdRatio*100); const tpmPct=Math.round(r.tpmRatio*100);
  const rf=document.getElementById('rlFillRPD'); if(rf){rf.style.width=rpdPct+'%'; rf.className='rl-meter-fill '+(rpdPct>80?'bad':rpdPct>50?'warn':'good');}
  const tf=document.getElementById('rlFillTPM'); if(tf){tf.style.width=tpmPct+'%'; tf.className='rl-meter-fill '+(tpmPct>80?'bad':tpmPct>50?'warn':'good');}
  const rt=document.getElementById('rlTextRPD'); if(rt)rt.textContent=r.rpdLeft;
  const tt=document.getElementById('rlTextTPM'); if(tt)tt.textContent=r.tpmLeft;
  const mn=document.getElementById('rlModelName'); if(mn)mn.textContent=currentModel().label;
  meter.classList.add('visible');
  clearTimeout(meter._hideTimer);
  meter._hideTimer=setTimeout(()=>meter.classList.remove('visible'),5000);
}

