// ── MARKDOWN RENDERER ──────────────────────────────────────────
function renderMarkdown(raw) {
  // Step 1: Extract code blocks to protect them from other processing
  const codeBlocks = [];
  let text = raw.replace(/```(\w*)\n?([\s\S]*?)```/g, (_, lang, code) => {
    const idx = codeBlocks.length;
    codeBlocks.push(`<pre><code>${escHtml(code.trim())}</code></pre>`);
    return `\x00CODE${idx}\x00`;
  });

  // Step 2: Extract inline code too
  const inlineCodes = [];
  text = text.replace(/`([^`\n]+)`/g, (_, code) => {
    const idx = inlineCodes.length;
    inlineCodes.push(`<code>${escHtml(code)}</code>`);
    return `\x00INLINE${idx}\x00`;
  });

  // Step 3: Escape HTML in remaining text
  text = escHtml(text);

  // Step 4: Re-allow <u> tags the model may output literally
  text = text.replace(/&lt;u&gt;([\s\S]*?)&lt;\/u&gt;/g, '<u>$1</u>');

  // Step 5: Apply inline formatting
  text = text.replace(/\*\*\*(.+?)\*\*\*/g, '<strong><em>$1</em></strong>');
  text = text.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>');
  text = text.replace(/\*([^*\n]+)\*/g, '<em>$1</em>');
  text = text.replace(/\+\+(.+?)\+\+/g, '<u>$1</u>');
  text = text.replace(/~~(.+?)~~/g, '<del>$1</del>');
  // Italic _word_ — only single words to avoid false positives in filenames
  text = text.replace(/(?<![a-zA-Z0-9])_([^_\n]+?)_(?![a-zA-Z0-9])/g, '<em>$1</em>');

  // Step 6: Process links
  text = text.replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2" target="_blank" rel="noopener">$1</a>');

  // Step 7: Process line by line
  const lines = text.split('\n');
  const output = [];
  let i = 0;

  while (i < lines.length) {
    const line = lines[i];
    const trimmed = line.trim();

    // Blank line
    if (!trimmed) { output.push(''); i++; continue; }

    // Blockquote
    if (trimmed.startsWith('&gt; ')) {
      output.push(`<blockquote>${trimmed.slice(5)}</blockquote>`);
      i++; continue;
    }

    // Horizontal rule
    if (/^[-*]{3,}$/.test(trimmed)) {
      output.push('<hr>');
      i++; continue;
    }

    // Headers
    const hm = trimmed.match(/^(#{1,4}) (.+)$/);
    if (hm) {
      const lvl = hm[1].length;
      output.push(`<h${lvl}>${hm[2]}</h${lvl}>`);
      i++; continue;
    }

    // Unordered list item
    if (/^[-*+] /.test(trimmed) || /^\s+[-*+] /.test(line)) {
      const items = [];
      while (i < lines.length && (/^(\s*)([-*+]) (.+)$/.test(lines[i]))) {
        const m = lines[i].match(/^(\s*)([-*+]) (.+)$/);
        const depth = m[1].length;
        items.push(`<li style="margin-left:${depth * 12}px">${m[3]}</li>`);
        i++;
      }
      output.push(`<ul>${items.join('')}</ul>`);
      continue;
    }

    // Ordered list item
    if (/^\d+\. /.test(trimmed) || /^\s+\d+\. /.test(line)) {
      const items = [];
      while (i < lines.length && /^(\s*)(\d+)\. (.+)$/.test(lines[i])) {
        const m = lines[i].match(/^(\s*)(\d+)\. (.+)$/);
        const depth = m[1].length;
        items.push(`<li style="margin-left:${depth * 12}px">${m[3]}</li>`);
        i++;
      }
      output.push(`<ol>${items.join('')}</ol>`);
      continue;
    }

    // Regular paragraph — collect consecutive non-special lines
    const para = [];
    while (i < lines.length) {
      const l = lines[i];
      const t = l.trim();
      if (!t) break;
      if (/^(#{1,4}) |^[-*+] |\s+[-*+] |^\d+\. |^&gt; |^[-*]{3,}$/.test(t)) break;
      if (t.startsWith('\x00CODE') || t.startsWith('\x00INLINE')) { break; }
      para.push(l);
      i++;
    }
    if (para.length) {
      output.push(`<p>${para.join('<br>')}</p>`);
      continue;
    }

    output.push(trimmed);
    i++;
  }

  let html = output.join('\n');

  // Step 8: Restore code blocks and inline code
  codeBlocks.forEach((block, idx) => {
    html = html.replace(`\x00CODE${idx}\x00`, block);
  });
  inlineCodes.forEach((code, idx) => {
    html = html.replace(`\x00INLINE${idx}\x00`, code);
  });

  // Step 9: Clean up
  html = html.replace(/<p>\s*<\/p>/g, '');

  return html;
}

function escHtml(s) {
  return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

