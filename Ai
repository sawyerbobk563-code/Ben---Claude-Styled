const HISTORY_KEY = 'ben_chat_history';
function loadChatHistory() { try { return JSON.parse(localStorage.getItem(HISTORY_KEY)) || []; } catch { return []; } }
function saveChatHistory(chats) { try { localStorage.setItem(HISTORY_KEY, JSON.stringify(chats)); } catch {} }

